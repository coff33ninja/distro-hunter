  "download": {
    "download_dir": "downloads",
    "page_cache_dir": "cache/pages",
    "page_cache_ttl_seconds": 3600,
    "discovery_workers": 8,
    "verify_checksums": true,
    "require_checksums": false,
    "aria2_path": "tools/aria2/aria2c.exe",
    "prefer_aria2": true,
    "prefer_torrent": false,
    "protect_filename_collisions": true,
    "retention_keep_latest": 1,
    "decompress_bz2": true,
    "connections_per_server": 8,
    "split": 8,
    "timeout_seconds": 30,
    "retry_attempts": 3,
    "retry_backoff_seconds": 1.0,
    "mirror_backoff_base_seconds": 1800,
    "mirror_backoff_cap_seconds": 21600,
    "user_agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36"
  },
  "ventoy": {
    "enabled": true,
    "volume_labels": [
      "Ventoy"
    ],
    "marker_paths": [
      "ventoy"
    ],
    "destination_subdir": "ISO/Linux",
    "copy_extensions": [
      ".iso",
      ".img"
    ],
    "organize_by_plugin": true,
    "manual_subdir": "manual",
    "manual_sources": [
      {
        "pattern": "bazzite-*.iso",
        "family": "bazzite",
        "edition_type": "desktop",
        "source_kind": "manual"
      }
    ],
    "prune_removed": false
  },
  "generator": {
    "output_dir": "user_plugins",
    "test_output_dir": "tests/generated"
  },
  "logging": {
    "run_log_file": "logs/distro_hunter.log",
    "mirror_failures_file": "logs/mirror_failures.log",
    "jsonl_log_file": "logs/distro_hunter.jsonl"
  }
}
